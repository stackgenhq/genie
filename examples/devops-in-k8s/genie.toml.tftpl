# DevOps Copilot Configuration
# ─────────────────────────────────────────────────────────────────────
# This file is a Terraform template (tftpl). Infrastructure values
# (hosts, ports, regions, secret names) are resolved at terraform apply
# time. Genie runtime secret references ($${VAR}) are passed through
# literally and resolved by the Genie binary at startup.
#
# Template variables (resolved by Terraform):
#   secrets_manager_name  — AWS Secrets Manager secret name
#   aws_region            — AWS region
#   qdrant_host           — Qdrant service FQDN
#   qdrant_port           — Qdrant gRPC port
#   qdrant_api_key        — Qdrant API key (optional, empty = disabled)
#   agui_port             — AG-UI server port
#
# Runtime placeholders (resolved by envsubst in init container):
#   $${POSTGRES_DSN}      — PostgreSQL DSN (from Kubernetes Secret)
# ─────────────────────────────────────────────────────────────────────

skills_roots = ["./skills"]
agent_name  = "devops-copilot"
[persona]
file = "/app/AGENTS.md"
disable_resume = true

[security]
[security.secrets]
"OPENAI_API_KEY" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=OPENAI_API_KEY"
"ANTHROPIC_API_KEY" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=ANTHROPIC_API_KEY"
"GEMINI_API_KEY" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=GEMINI_API_KEY"
"GITHUB_TOKEN" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=GITHUB_TOKEN"
"GRAFANA_URL" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=GRAFANA_URL"
"GRAFANA_API_KEY" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=GRAFANA_API_KEY"
"LANGFUSE_PUBLIC_KEY" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=LANGFUSE_PUBLIC_KEY"
"LANGFUSE_SECRET_KEY" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=LANGFUSE_SECRET_KEY"
"LANGFUSE_HOST" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=LANGFUSE_HOST"
"OIDC_ISSUER_URL" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=OIDC_ISSUER_URL"
"OIDC_CLIENT_ID" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=OIDC_CLIENT_ID"
"OIDC_CLIENT_SECRET" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=OIDC_CLIENT_SECRET"
"AGUI_COOKIE_SECRET" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=AGUI_COOKIE_SECRET"
%{ if qdrant_api_key != "" ~}
"QDRANT_API_KEY" = "awssecretsmanager://${secrets_manager_name}?region=${aws_region}&decoder=string&path=QDRANT_API_KEY"
%{ endif ~}

[db_config]
# PostgreSQL — DSN is injected from Kubernetes Secret via envsubst in
# the credential-bootstrap init container. The literal POSTGRES_DSN
# placeholder is resolved at container start time, NOT by Terraform.
dsn = "$${POSTGRES_DSN}"

# ── Model Configuration ─────────────────────────────────────────────
[model_config]

# Planning model: Sonnet is the right tier for orchestration (read notes,
# spawn sub-agents, synthesize). Opus was 10x more expensive with no benefit
# for routing/delegation tasks — see trace analysis showing $0.76/trace waste.
[[model_config.providers]]
provider = "anthropic"
model_name = "claude-sonnet-4-5-20250929"
token = "$${ANTHROPIC_API_KEY}"
good_for_task = "planning"

# [[model_config.providers]]
# provider = "openai"
# model_name = "o4-mini"
# token = "$${OPENAI_API_KEY}"
# good_for_task = "planning"

[[model_config.providers]]
provider = "gemini"
model_name = "gemini-3-flash-preview"
token = "$${GEMINI_API_KEY}"
good_for_task = "tool_calling"

[[model_config.providers]]
provider = "gemini"
model_name = "gemini-3-pro-preview"
token = "$${GEMINI_API_KEY}"
good_for_task = "summarizer"

[[model_config.providers]]
provider = "gemini"
model_name = "gemini-3-flash-preview"
token = "$${GEMINI_API_KEY}"
good_for_task = "terminal_calling"

[[model_config.providers]]
provider = "gemini"
model_name = "gemini-3-flash-preview"
token = "$${GEMINI_API_KEY}"
good_for_task = "frontdesk"

[[model_config.providers]]
provider = "openai-completions"
model_name = "gpt-5.1-codex-mini"
token = "$${OPENAI_API_KEY}"
good_for_task = "general_task"

[[model_config.providers]]
provider = "openai-completions"
model_name = "gpt-5.3-codex"
token = "$${OPENAI_API_KEY}"
good_for_task = "coding"

# ── Efficiency models (used by halguard for cross-model verification) ──
# These fast/cheap models from 3 different providers give halguard
# diverse cross-model samples for hallucination detection.

[[model_config.providers]]
provider = "openai"
model_name = "gpt-4.1-mini"
token = "$${OPENAI_API_KEY}"
good_for_task = "efficiency"

[[model_config.providers]]
provider = "gemini"
model_name = "gemini-2.0-flash"
token = "$${GEMINI_API_KEY}"
good_for_task = "efficiency"

[[model_config.providers]]
provider = "anthropic"
model_name = "claude-haiku-4-5"
token = "$${ANTHROPIC_API_KEY}"
good_for_task = "efficiency"

[[model_config.providers]]
provider = "gemini"
model_name = "gemini-3-flash-preview"
token = "$${GEMINI_API_KEY}"
good_for_task = "efficiency"

# ── Hallucination Guard ─────────────────────────────────────────────
# Pre-check scores sub-agent goals for fabrication risk (role-play,
# invented metrics, etc.). Post-check uses cross-model verification
# on outputs using the efficiency models above.
[halguard]
enable_pre_check = true
enable_post_check = true
pre_check_threshold = 0.4
cross_model_samples = 3

# ── MCP Servers ─────────────────────────────────────────────────────
# Each MCP server gives Genie structured access to a DevOps platform.
# Enable only the servers you have credentials for.

[mcp]

# ── Observability ───────────────────────────────────────────────────

# Grafana: dashboards, alerts, datasources, explore queries
[[mcp.servers]]
name = "grafana"
transport = "stdio"
command = "npx"
args = ["-y", "@anthropic/grafana-mcp-server"]
env = { GRAFANA_URL = "$${GRAFANA_URL}", GRAFANA_API_KEY = "$${GRAFANA_API_KEY}" }

# Datadog: metrics, logs, traces, incidents, dashboards, monitors
# [[mcp.servers]]
# name = "datadog"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/datadog-mcp-server"]
# env = { DD_API_KEY = "$${DD_API_KEY}", DD_APP_KEY = "$${DD_APP_KEY}" }

# Sentry: error tracking, issues, events
# [[mcp.servers]]
# name = "sentry"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/sentry-mcp-server"]
# env = { SENTRY_AUTH_TOKEN = "$${SENTRY_AUTH_TOKEN}" }

# ── Source Control & CI/CD ──────────────────────────────────────────

# GitHub: repos, PRs, issues, actions, code search
[[mcp.servers]]
name = "github"
transport = "stdio"
command = "npx"
args = ["-y", "@anthropic/github-mcp-server"]
env = { GITHUB_TOKEN = "$${GITHUB_TOKEN}" }

# GitLab (uncomment if using GitLab instead)
# [[mcp.servers]]
# name = "gitlab"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/gitlab-mcp-server"]
# env = { GITLAB_TOKEN = "$${GITLAB_TOKEN}" }

# ── Infrastructure ──────────────────────────────────────────────────

# Terraform: validate, plan, state inspection
[[mcp.servers]]
name = "terraform"
transport = "stdio"
command = "npx"
args = ["-y", "@anthropic/terraform-mcp-server"]

# Kubernetes: pods, services, deployments, namespaces
# [[mcp.servers]]
# name = "kubernetes"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/kubernetes-mcp-server"]
# env = { KUBECONFIG = "$${KUBECONFIG}" }

# ── Collaboration ───────────────────────────────────────────────────

# Atlassian (Jira + Confluence)
# [[mcp.servers]]
# name = "atlassian"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/atlassian-mcp-server"]
# env = { ATLASSIAN_URL = "$${ATLASSIAN_URL}", ATLASSIAN_EMAIL = "$${ATLASSIAN_EMAIL}", ATLASSIAN_API_TOKEN = "$${ATLASSIAN_API_TOKEN}" }

# PagerDuty: incidents, services, escalation policies
# [[mcp.servers]]
# name = "pagerduty"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/pagerduty-mcp-server"]
# env = { PAGERDUTY_API_KEY = "$${PAGERDUTY_API_KEY}" }

