# name = "postgres"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/postgres-mcp-server"]
# env = { DATABASE_URL = "$${DATABASE_URL}" }

# ── Application Settings ────────────────────────────────────────────

[ops]
max_pages = 5
enable_verification = true
max_verification_runs = 3

# ── Langfuse Observability ──────────────────────────────────────────
[langfuse]
public_key = "$${LANGFUSE_PUBLIC_KEY}"
secret_key = "$${LANGFUSE_SECRET_KEY}"
host       = "$${LANGFUSE_HOST}"

# ── GitHub (SCM) ────────────────────────────────────────────────────
[scm]
provider = "github"
token = "$${GITHUB_TOKEN}"

# ── GitHub CLI (gh_cli tool) ────────────────────────────────────────
# Bootstraps the gh_cli agent tool only when the gh binary is on PATH
# AND a token is configured. The token is injected per-subprocess via
# GH_TOKEN — never persisted to disk or shell config.
[ghcli]
token = "$${GITHUB_TOKEN}"

# ── Knowledge Graph ─────────────────────────────────────────────────
# Store entities and relations in the same Qdrant collection as vector memory.
# Without this, the graph defaults to a volatile in-memory store that loses
# all data on pod restart.
[graph]
backend = "vectorstore"

# ── Vector Memory ───────────────────────────────────────────────────
[vector_memory]
vector_store_provider = "qdrant"
embedding_provider = "openai"
openai_model = "text-embedding-3-small"
api_key = "$${OPENAI_API_KEY}"

[vector_memory.qdrant]
host = "${qdrant_host}"
port = ${qdrant_port}
collection_name = "genie_documents"
%{ if qdrant_api_key != "" ~}
api_key = "$${QDRANT_API_KEY}"
%{ endif ~}

# ── AG-UI Server ────────────────────────────────────────────────────
[messenger.agui]
port = ${agui_port}
cors_origins = ["https://stackgenhq.github.io", "http://localhost:8123"]
rate_limit = 16.67
rate_burst = 100

# OIDC (Single Sign-On) is configured as the active auth method.
# To use password-based auth instead, comment out this OIDC section and
# uncomment the password section below. Supply OIDC values via variables.tf.
[messenger.agui.auth.oidc]
issuer_url = "$${OIDC_ISSUER_URL}"
client_id = "$${OIDC_CLIENT_ID}"
client_secret = "$${OIDC_CLIENT_SECRET}"
cookie_secret = "$${AGUI_COOKIE_SECRET}"
allowed_domains = ["stackgen.com"]


# ── AG-UI Authentication ────────────────────────────────────────────
# Password protection is enabled by default. Set the auth.password value
# (for example via the Terraform variable path var.auth.password or its
# corresponding environment-variable wiring in this example) to use a
# static password. If left empty, an auto-generated password will be
# logged during container startup.
# [messenger.agui.auth.password]
# enabled = true

[hitl]
# Auto-approve graph, and SCM tools for autonomous/background agents.
# Without this, sub-agents block for their entire timeout (180s) waiting for
# human approval that never comes in headless sessions.
always_allowed = ["graph_*", "scm_*"]

# ── PII Redaction ───────────────────────────────────────────────────
# Tuned for DevOps agents: infrastructure output is full of mixed-case
# identifiers, resource names, and table data that trigger false positives
# at the default threshold. We raise entropy_threshold and min_secret_length,
# and add safe_regexes for AWS and Azure resource patterns.
[pii]
entropy_threshold = 4.8    # Default 4.2 is too aggressive for infra output
min_secret_length = 16     # Default 6 catches resource names; real secrets are longer

# ── AWS Safe Patterns ───────────────────────────────────────────────

[[pii.safe_regexes]]
name = "aws_profile"
pattern = '\b[0-9]{12}_[A-Za-z0-9_-]+\b'

[[pii.safe_regexes]]
name = "aws_arn"
pattern = '(?i)arn:aws:[a-z0-9-]+:[a-z0-9-]*:[0-9]{12}:[a-zA-Z0-9-/_]+'

[[pii.safe_regexes]]
name = "aws_resource_id"
pattern = '(?i)(i|vol|snap|ami|subnet|vpc|igw|nat|eni|sg|rtb|eipalloc)-[0-9a-f]{8,17}'

[[pii.safe_regexes]]
name = "s3_bucket"
pattern = '(?i)[a-z0-9.-]+\.s3\.[a-z0-9-]+\.amazonaws\.com'

# ── Azure Safe Patterns ─────────────────────────────────────────────

[[pii.safe_regexes]]
name = "azure_subscription_id"
pattern = '(?i)[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}'

[[pii.safe_regexes]]
name = "azure_resource_id"
pattern = '(?i)/subscriptions/[0-9a-f-]+/resourceGroups/[A-Za-z0-9_.-]+(/providers/[A-Za-z0-9._-]+)*'

[[pii.safe_regexes]]
name = "azure_resource_group"
pattern = '(?i)\b[a-z][a-z0-9_-]{2,63}\b'

[[pii.safe_regexes]]
name = "azure_vm_size"
pattern = '(?i)Standard_[A-Za-z0-9_]+[sv][0-9]+'

[[pii.safe_regexes]]
name = "azure_disk_state"
pattern = '(?i)\b(Attached|Unattached|Reserved|ActiveSAS|ReadyToUpload)\b'

[[pii.safe_regexes]]
name = "azure_region"
pattern = '(?i)\b(eastus|eastus2|westus|westus2|westus3|centralus|northcentralus|southcentralus|westcentralus|canadacentral|canadaeast|northeurope|westeurope|uksouth|ukwest|francecentral|francesouth|germanywestcentral|norwayeast|swedencentral|switzerlandnorth|australiaeast|australiasoutheast|eastasia|southeastasia|japaneast|japanwest|koreacentral|koreasouth|centralindia|southindia|westindia|brazilsouth|uaenorth|southafricanorth|qatarcentral)\b'

[[pii.safe_regexes]]
name = "azure_power_state"
pattern = '(?i)\bVM (running|deallocated|stopped|starting|deallocating)\b'

# ── General Cloud Infrastructure Patterns ───────────────────────────

[[pii.safe_regexes]]
name = "kubernetes_version"
pattern = '(?i)\bv?[0-9]+\.[0-9]+\.[0-9]+(-[a-z0-9.]+)?\b'

[[pii.safe_regexes]]
name = "cloud_resource_type"
pattern = '(?i)\b(VirtualMachines|VMScaleSets|virtualNetworks|storageAccounts|containerRegistries|aksCluster|managedClusters|networkSecurityGroups|publicIPAddresses|loadBalancers|keyVaults|disks|snapshots|networkInterfaces)\b'

[[pii.safe_regexes]]
name = "provisioning_state"
pattern = '(?i)\b(Succeeded|Failed|Creating|Updating|Deleting|Canceled|InProgress|Registered|NotRegistered)\b'
