# ─────────────────────────────────────────────────────────────────────────────
# Genie Terraform Variables – Example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────

aws_region       = "us-west-2"
eks_cluster_name = "my-cluster"

# ARN of the AWS Secrets Manager secret containing your API keys.
# The secret must be a JSON object with keys matching external_secret_keys.
# Example: arn:aws:secretsmanager:us-west-2:123456789012:secret:genie/api-keys-AbCdEf
aws_secrets_manager_arn = ""

# ── Optional ────────────────────────────────────────────────────────────────

namespace        = "genie"
create_namespace = true
genie_image      = "ghcr.io/stackgenhq/genie:latest"
genie_replicas   = 1
container_port   = 9876
ingress_host     = "genie.example.com"

# Ingress class and annotations – adjust for your cluster's ingress controller
ingress_class_name = "nginx"
ingress_annotations = {
  # NGINX Inc (nginx.org) controller:
  # "nginx.org/mergeable-ingress-type" = "minion"
  #
  # NGINX Kubernetes Ingress (kubernetes.github.io) controller:
  # "nginx.ingress.kubernetes.io/rewrite-target" = "/"
}

# Feature flags
enable_irsa             = true   # Create IAM role with ReadOnlyAccess via IRSA
enable_external_secrets = true   # Create SecretStore + ExternalSecret (requires ESO)

# Path to genie.toml (relative to this directory)
genie_config_file = "genie.toml"

# Secret keys to sync from AWS Secrets Manager → K8s Secret "genie-secrets"
# Keys = K8s secret data key names, Values = Secrets Manager JSON property names
# Add or remove entries as needed for your configuration.
external_secret_keys = {
  OPENAI_API_KEY    = "OPENAI_API_KEY"
  ANTHROPIC_API_KEY = "ANTHROPIC_API_KEY"
  GEMINI_API_KEY    = "GEMINI_API_KEY"
  GITHUB_TOKEN      = "GITHUB_TOKEN"
  GRAFANA_URL       = "GRAFANA_URL"
  GRAFANA_API_KEY   = "GRAFANA_API_KEY"
}
